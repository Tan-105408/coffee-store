<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thanh toán bị hủy - Coffee Store</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="container">
      <h1>☕ Coffee Store</h1>
      <nav>
        <a href="/">Trang chủ</a>
        <a href="/cart">Giỏ hàng</a>
      </nav>
    </div>
  </header>
  
  <main class="container" style="text-align: center; padding: 100px 0;">
    <div style="background: white; padding: 50px; border-radius: 12px; box-shadow: var(--shadow); max-width: 600px; margin: 0 auto;">
      <div style="font-size: 5rem; color: #e74c3c; margin-bottom: 20px;">!</div>
      <h2 style="color: var(--primary-color); margin-bottom: 20px;"><%= typeof message !== 'undefined' ? message : 'Thanh toán đã bị hủy' %></h2>
      <p style="color: var(--light-text); margin-bottom: 30px;">Giao dịch của bạn đã bị hủy hoặc gặp sự cố. Bạn có thể thử lại hoặc chọn phương thức thanh toán khác.</p>
      <div style="display: flex; gap: 15px; justify-content: center;">
        <a href="/cart" class="product-button view-details" style="text-decoration: none; padding: 12px 30px;">Về giỏ hàng</a>
        <a href="/" class="product-button add-to-cart" style="text-decoration: none; padding: 12px 30px;">Tiếp tục xem món</a>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="footer-bottom">
        <p>&copy; 2026 Coffee Store. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>
