<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - Coffee Store</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .product-detail-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      margin-top: 50px;
      background: var(--white);
      padding: 40px;
      border-radius: 12px;
      box-shadow: var(--shadow);
    }
    .detail-image {
      width: 100%;
      height: 400px;
      object-fit: cover;
      border-radius: 12px;
    }
    .detail-info h2 {
      text-align: left;
      margin-bottom: 20px;
      color: var(--primary-color);
    }
    .detail-price {
      font-size: 1.8rem;
      color: var(--accent-color);
      font-weight: bold;
      margin: 20px 0;
    }
    .detail-description {
      color: var(--light-text);
      margin-bottom: 30px;
      font-size: 1.1rem;
    }
    .review-section {
      margin-top: 50px;
    }
    .review-card {
      background: var(--white);
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 15px;
      border-left: 4px solid var(--accent-color);
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>☕ Coffee Store</h1>
      <nav>
        <a href="/">Trang chủ</a>
        <a href="/cart">Giỏ hàng</a>
        <% if (user) { %>
          <div class="user-info">
            <span>👋 <%= user.username %></span>
            <a href="/auth/profile">Hồ sơ</a>
          </div>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container">
    <div class="product-detail-container">
      <img src="<%= product.image %>" alt="<%= product.name %>" class="detail-image" />
      
      <div class="detail-info">
        <h2><%= product.name %></h2>
        <p class="detail-description"><%= product.description || 'Hương vị tuyệt hảo từ những hạt cà phê tuyển chọn, mang lại cảm giác sảng khoái cho ngày mới của bạn.' %></p>
        
        <div class="detail-price">
           <% if (product.discount > 0) { %>
            <span style="text-decoration: line-through; color: #999; font-size: 1.2rem; margin-right: 15px;"><%= product.price.toLocaleString() %>đ</span>
            <span><%= (product.price * (1 - product.discount / 100)).toLocaleString() %>đ</span>
          <% } else { %>
            <%= product.price.toLocaleString() %>đ
          <% } %>
        </div>

        <div class="modal-quantity-container">
          <label for="quantity">Số lượng:</label>
          <input type="number" id="quantity" value="1" min="1" class="modal-quantity" style="width: 80px; padding: 10px;">
        </div>

        <p id="total-price-display" style="font-size: 1.2rem; margin-bottom: 20px; font-weight: 600;">
          Tổng tiền: <span id="total-amount"><%= (product.price * (1 - product.discount / 100)).toLocaleString() %>đ</span>
        </p>

        <button id="add-to-cart-btn" class="product-button add-to-cart" data-id="<%= product.id %>" style="width: 250px; padding: 15px; font-size: 1.1rem;">
          Thêm vào giỏ hàng
        </button>
      </div>
    </div>

    <section class="review-section">
      <h3 class="section-title" style="text-align: left;">Đánh giá từ khách hàng</h3>
      <% if (reviews && reviews.length > 0) { %>
        <% reviews.forEach(review => { %>
          <div class="review-card">
            <p style="font-weight: 600; margin-bottom: 5px;"><%= review.user.username %></p>
            <div style="color: #f39c12; margin-bottom: 10px;">
              <% for(let i=0; i<review.rating; i++) { %>★<% } %>
            </div>
            <p style="color: var(--text-color);"><%= review.comment %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p style="color: var(--light-text);">Chưa có đánh giá nào cho sản phẩm này.</p>
      <% } %>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="footer-bottom">
        <p>&copy; 2026 Coffee Store. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
  <script>
    const basePrice = <%= (product.price * (1 - product.discount / 100)) %>;
    const quantityInput = document.getElementById("quantity");
    const totalAmountSpan = document.getElementById("total-amount");

    quantityInput.addEventListener("input", () => {
      const qty = parseInt(quantityInput.value) || 1;
      const total = basePrice * qty;
      totalAmountSpan.textContent = total.toLocaleString() + "đ";
    });
  </script>
</body>
</html>
