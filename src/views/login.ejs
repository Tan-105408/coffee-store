<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - Coffee Store</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .auth-container {
      max-width: 400px;
      margin: 80px auto;
      background: var(--white);
      padding: 40px;
      border-radius: 12px;
      box-shadow: var(--shadow);
    }
    .auth-container h2 {
      margin-bottom: 25px;
      color: var(--primary-color);
    }
    .auth-container form input {
      margin-bottom: 15px;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 8px;
    }
    .social-login {
      margin-top: 25px;
      padding-top: 20px;
      border-top: 1px solid #eee;
      text-align: center;
    }
    .google-btn {
      display: inline-block;
      width: 100%;
      padding: 10px;
      background-color: #fff;
      border: 1px solid #ddd;
      border-radius: 8px;
      text-decoration: none;
      color: #555;
      font-weight: 600;
      transition: var(--transition);
      cursor: pointer;
      font-family: inherit;
      font-size: 1rem;
    }
    .google-btn:hover {
      background-color: #f9f9f9;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>☕ Coffee Store</h1>
      <nav>
        <a href="/">Trang chủ</a>
        <a href="/cart">Giỏ hàng</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <div class="auth-container">
      <h2>Chào mừng trở lại!</h2>
      <form action="/auth/login" method="POST">
        <input type="text" name="username" placeholder="Tên đăng nhập" required>
        <input type="password" name="password" placeholder="Mật khẩu" required>
        <button type="submit" class="product-button add-to-cart" style="width: 100%;">Đăng nhập</button>
      </form>
      
      <div class="social-login">
        <p style="margin-bottom: 15px; font-size: 0.9rem; color: var(--light-text);">Hoặc tiếp tục với</p>
        <button id="googleLoginBtn" class="google-btn">
          <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" alt="Google" style="width: 18px; vertical-align: middle; margin-right: 10px;">
          Google
        </button>
      </div>

      <p style="margin-top: 20px; text-align: center; font-size: 0.9rem;">
        Chưa có tài khoản? <a href="/auth/register" style="color: var(--accent-color); font-weight: 600;">Đăng ký ngay</a>
      </p>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="footer-bottom">
        <p>&copy; 2026 Coffee Store. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getAuth, signInWithPopup, GoogleAuthProvider } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

    const firebaseConfig = {
      apiKey: "AIzaSyCOvNzdoiBjG9A-a0S-gp1QlZ0yqfQcrWU",
      authDomain: "test-9df88.firebaseapp.com",
      projectId: "test-9df88",
      storageBucket: "test-9df88.firebasestorage.app",
      messagingSenderId: "751328612024",
      appId: "1:751328612024:web:0fcfec9eb2e570da572e4d",
      measurementId: "G-HGJWE7C09Q"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();
    provider.setCustomParameters({
      prompt: 'select_account'
    });

    document.getElementById('googleLoginBtn').addEventListener('click', async () => {
      try {
        const result = await signInWithPopup(auth, provider);
        const idToken = await result.user.getIdToken();

        const response = await fetch('/auth/google', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ idToken })
        });

        const data = await response.json();
        if (response.ok) {
          window.location.href = data.redirectUrl || '/';
        } else {
          alert(data.message || 'Đăng nhập Google thất bại');
        }
      } catch (error) {
        console.error("Google login error:", error);
        alert("Lỗi khi đăng nhập bằng Google: " + error.message);
      }
    });
  </script>
</body>
</html>
