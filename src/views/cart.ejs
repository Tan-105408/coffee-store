<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng của bạn - Coffee Store</title>
    <link rel="stylesheet" href="/style.css" />
    <style>
      .cart-table {
        width: 100%;
        border-collapse: collapse;
        margin: 30px 0;
        background: var(--white);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow);
      }
      .cart-table th, .cart-table td {
        padding: 15px;
        text-align: left;
        border-bottom: 1px solid #eee;
      }
      .cart-table th {
        background-color: var(--primary-color);
        color: var(--white);
      }
      .cart-item-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
      }
      .cart-summary {
        background-color: var(--white);
        padding: 25px;
        border-radius: 12px;
        box-shadow: var(--shadow);
        max-width: 400px;
        margin-left: auto;
      }
      .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 1.1rem;
      }
      .summary-total {
        border-top: 2px solid #eee;
        padding-top: 15px;
        font-weight: bold;
        color: var(--accent-color);
        font-size: 1.4rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <h1>☕ Coffee Store</h1>
        <nav>
          <a href="/">Trang chủ</a>
          <a href="/cart">Giỏ hàng</a>
          <% if (user) { %>
            <div class="user-info">
              <span>👋 <%= user.username %></span>
              <a href="/auth/profile">Hồ sơ</a>
              <a href="/auth/logout">Đăng xuất</a>
            </div>
          <% } else { %>
            <a href="/auth/login">Đăng nhập</a>
            <a href="/auth/register">Đăng ký</a>
          <% } %>
        </nav>
      </div>
    </header>

    <main class="container">
      <h2 class="section-title" style="margin-top: 40px;">Giỏ hàng của bạn</h2>

      <% if (cart && cart.length > 0) { %>
        <table class="cart-table">
          <thead>
            <tr>
              <th>Sản phẩm</th>
              <th>Đơn giá</th>
              <th>Số lượng</th>
              <th>Thành tiền</th>
              <th>Hành động</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(item => { %>
              <tr>
                <td>
                  <div style="display: flex; align-items: center; gap: 15px;">
                    <img src="<%= item.product.image %>" alt="<%= item.product.name %>" class="cart-item-img" />
                    <span><%= item.product.name %></span>
                  </div>
                </td>
                <td>
                   <% if (item.product.discount > 0) { %>
                    <div style="display: flex; flex-direction: column;">
                      <span style="text-decoration: line-through; color: #999; font-size: 0.8rem;"><%= item.product.price.toLocaleString() %>đ</span>
                      <span><%= item.priceAfterDiscount.toLocaleString() %>đ</span>
                    </div>
                  <% } else { %>
                    <%= item.product.price.toLocaleString() %>đ
                  <% } %>
                </td>
                <td><%= item.quantity %></td>
                <td><%= item.total.toLocaleString() %>đ</td>
                <td>
                  <button class="remove-item product-button view-details" data-id="<%= item.product.id %>" style="width: auto; padding: 5px 15px;">
                    Xóa
                  </button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>

        <div class="cart-summary">
          <div class="summary-row">
            <span>Tạm tính:</span>
            <span><%= total.toLocaleString() %>đ</span>
          </div>
          <div class="summary-row summary-total">
            <span>Tổng cộng:</span>
            <span><%= total.toLocaleString() %>đ</span>
          </div>
          <a href="/checkout" class="product-button add-to-cart" style="display: block; width: 100%; margin-top: 20px; text-decoration: none;">
            Tiến hành thanh toán
          </a>
        </div>
      <% } else { %>
        <div style="text-align: center; padding: 100px 0;">
          <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="Empty Cart" style="width: 150px; opacity: 0.5; margin-bottom: 20px;" />
          <p style="font-size: 1.2rem; color: var(--light-text); margin-bottom: 20px;">Giỏ hàng của bạn đang trống!</p>
          <a href="/" class="product-button add-to-cart" style="text-decoration: none; padding: 10px 30px;">Mua sắm ngay</a>
        </div>
      <% } %>
    </main>

    <footer>
      <div class="container">
        <div class="footer-bottom">
          <p>&copy; 2026 Coffee Store. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script src="/script.js"></script>
  </body>
</html>
